      mixpanel.init('aac809f91ad62a7638d555013af6b6db', {
        autocapture: true,
        record_sessions_percent: 100,
      })

    </script>
  </head>
  <body>
    <slot />
    <script>
      import '../scripts/animations';
    </script>
    <script>
      const titlePromptWindow = window as Window & {
        __returnTitlePromptCleanup?: () => void;
      };

      titlePromptWindow.__returnTitlePromptCleanup?.();

      const awayTitle = "Psst! Let's talk about your next project";
      let activeTitle = document.title;

      const syncActiveTitle = () => {
        if (!document.hidden) {
          activeTitle = document.title;
        }
      };

      const handleVisibilityChange = () => {
        if (document.hidden) {
          activeTitle = document.title;
          document.title = awayTitle;
          return;
        }

        document.title = activeTitle;
      };

      document.addEventListener('visibilitychange', handleVisibilityChange);
      document.addEventListener('astro:page-load', syncActiveTitle);

      titlePromptWindow.__returnTitlePromptCleanup = () => {
        document.removeEventListener('visibilitychange', handleVisibilityChange);
        document.removeEventListener('astro:page-load', syncActiveTitle);
      };
    </script>
  </body>
</html>
