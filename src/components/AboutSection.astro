---
---

<section class="section about-section" aria-labelledby="about-title">
  <div class="section-content about-section__content-panel">
    <div class="about-section__content">
      <div class="about-section__intro">
        <p class="about-section__eyebrow">
          <span class="about-section__eyebrow-dot" aria-hidden="true"></span>
          <span>About me</span>
        </p>

        <h2 id="about-title" class="about-section__title">
          I build intentional digital platforms for market leaders. By integrating business strategy,
          brand identity, and high-performance development under a single vision. I eliminate the gap
          between who you are and how the world sees you online.
        </h2>
      </div>

      <div class="about-section__metric" aria-label="Years of experience">
        <div class="about-section__metric-header">
          <p>Years of experience</p>
          <p>2 of 4</p>
        </div>

        <div class="about-section__metric-body">
          <p class="about-section__metric-value">9+</p>
          <div class="about-section__metric-actions" aria-hidden="true">
            <span class="about-section__arrow about-section__arrow--down"></span>
            <span class="about-section__arrow about-section__arrow--up"></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="about-section__media">
    <img
      class="about-section__image"
      src="/brand/about-main.png"
      alt=""
      loading="lazy"
      aria-hidden="true"
    />
    <img
      class="about-section__avatar"
      src="/brand/about-avatar.png"
      alt=""
      loading="lazy"
      aria-hidden="true"
    />
  </div>
</section>
