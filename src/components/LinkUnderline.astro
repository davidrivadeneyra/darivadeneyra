---
interface Props {
  label?: string;
  href?: string;
  state?: 'active' | 'inactive' | 'Active' | 'Inactive';
  type?: 'button' | 'submit' | 'reset';
  newPage?: boolean;
}

const {
  label = 'Home',
  href,
  state = 'inactive',
  type = 'button',
  newPage = false
} = Astro.props;

const normalizedState = state.toLowerCase() === 'active' ? 'active' : 'inactive';
const normalizedLabel = label
  ? label.charAt(0).toUpperCase() + label.slice(1).toLowerCase()
  : '';
const underlineMode = normalizedState === 'active' ? 'alt' : true;
---

<a
  class:list={[
    'underline-link',
    normalizedState === 'active' ? 'underline-link--active' : 'underline-link--inactive'
  ]}
  href={href}
  type={href ? undefined : type}
  target={href && newPage ? '_blank' : undefined}
  rel={href && newPage ? 'noopener noreferrer' : undefined}
  data-underline-link={underlineMode}
  data-state={normalizedState}
>
  {normalizedLabel}
</a>
